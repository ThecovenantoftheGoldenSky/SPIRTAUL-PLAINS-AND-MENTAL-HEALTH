Complete Instructions for Developers
QUICK START (For Experienced Devs)
bash
# 1. Clone the repo
git clone https://github.com/your-org/spiritual-planes.git
cd spiritual-planes

# 2. Install dependencies
npm install
pip install -r requirements.txt

# 3. Set up environment
cp .env.example .env
# Edit .env with your API keys

# 4. Start the database
docker-compose up -d postgres redis

# 5. Run migrations
npm run db:migrate

# 6. Seed initial data
npm run db:seed

# 7. Start development servers
npm run dev          # Backend (Node.js + Express)
npm run ai:dev       # AI Engine (Python + FastAPI)
