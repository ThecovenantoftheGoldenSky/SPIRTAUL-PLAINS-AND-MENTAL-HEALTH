12. TROUBLESHOOTING
Common Issues
"Cannot connect to database"
bash
# Check if PostgreSQL is running
docker-compose ps

# Restart database
docker-compose restart postgres

# Check logs
docker-compose logs postgres
"AI engine returns 500 errors"
bash
# Check if API keys are set
cat .env | grep OPENAI

# Test AI engine directly
curl http://localhost:8000/health

# Restart AI engine
uvicorn src.main:app --reload --port 8000
"Mobile app won't build"
bash
# Clear caches
npx react-native start --reset-cache
cd ios && pod deintegrate && pod install

# Clean build
npx react-native clean-project-auto
"WebSocket connection fails"
bash
# Check backend is running
curl http://localhost:3000/health

# Check CORS settings in .env
cat .env | grep CORS

# Verify WebSocket URL in mobile app
cat apps/mobile/src/services/websocket.ts
Performance Issues
Slow AI responses
bash
# Enable response caching in AI engine
REDIS_CACHE_TTL=300

# Use lighter model for development
OPENAI_MODEL=gpt-3.5-turbo

# Enable connection pooling
UVICORN_WORKERS=4
High memory usage
bash
# Monitor memory
npm run monitor:memory

# Optimize entity generation batch size
ENTITY_BATCH_SIZE=5

# Enable garbage collection
NODE_OPTIONS="--max-old-space-size=4096 --expose-gc"
