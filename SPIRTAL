5. CORE GAMEPLAY MECHANICS
5.1 The Session
Session Generation Algorithm
Python
def generate_session(player_level, player_faith, player_chaos):
    # Base entity count: 4-6
    base_count = min(4 + (player_level // 5), 6)

    # Always include Guardian and Adversary
    entities = ['guardian', 'adversary']

    # Add based on player state
    if player_chaos > 60:
        entities.append('wounded_performer')  # Player needs healing
    if player_faith < 40:
        entities.append('siren')  # Player is vulnerable
    if player_level > 3:
        entities.append('truth_teller')  # Player ready for deeper discernment

    # Fill remaining slots randomly
    possible = ['watcher', 'family_mimic', 'contrarian', 'cover_up',
                'atheist_ghost', 'nation', 'archon', 'hellish_observer',
                'storm_seeker', 'saboteur']
    remaining = base_count - len(entities)
    entities.extend(random.sample(possible, remaining))

    # Shuffle order so Guardian isn't always first
    random.shuffle(entities)

    return entities
