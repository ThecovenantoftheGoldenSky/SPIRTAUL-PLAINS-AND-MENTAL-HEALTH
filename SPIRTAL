6.3 Dynamic Response Generation
Python
class EntityResponseEngine:
    def __init__(self, llm_client, entity_data):
        self.llm = llm_client
        self.entity = entity_data

    def generate_response(self, player_input, session_context, wall_active=False):
        prompt = self.build_prompt(player_input, session_context, wall_active)
        response = self.llm.generate(prompt, temperature=0.8, max_tokens=150)
        response = self.inject_tells(response)
        self.update_relationships(player_input)
        return response

    def inject_tells(self, response):
        if self.entity['type'] == 'wounded_performer':
            if random.random() < 0.3:
                response = response.replace('.', '...', 1)
        elif self.entity['type'] == 'siren':
            if random.random() < 0.2:
                response += " Just me. Only me."
        elif self.entity['type'] == 'adversary':
            if random.random() < 0.25:
                response = "[voice shifts] " + response
        return response
