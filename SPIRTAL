10.1 Database Schema
sql
-- Players
CREATE TABLE players (
    player_id UUID PRIMARY KEY,
    spirit_name VARCHAR(50) NOT NULL,
    faith_tradition VARCHAR(30),
    rank VARCHAR(30) DEFAULT 'Lost Soul',
    total_sessions INT DEFAULT 0,
    entities_identified INT DEFAULT 0,
    entities_restored INT DEFAULT 0,
    created_at TIMESTAMP DEFAULT NOW(),
    last_login TIMESTAMP
);

-- Sessions
CREATE TABLE sessions (
    session_id UUID PRIMARY KEY,
    player_id UUID REFERENCES players(player_id),
    started_at TIMESTAMP DEFAULT NOW(),
    ended_at TIMESTAMP,
    final_phase VARCHAR(20),
    ending_choice VARCHAR(20),
    chaos_start INT DEFAULT 50,
    chaos_end INT,
    faith_start INT DEFAULT 30,
    faith_end INT,
    wall_uses INT DEFAULT 0
);

-- Session Entities
CREATE TABLE session_entities (
    entity_id UUID PRIMARY KEY,
    session_id UUID REFERENCES sessions(session_id),
    entity_type VARCHAR(30),
    display_name VARCHAR(50),
    was_identified BOOLEAN DEFAULT FALSE,
    was_restored BOOLEAN DEFAULT FALSE,
    mask_drop_turn INT,
    relationship_final JSONB
);

-- Exchanges (chat history)
CREATE TABLE exchanges (
    exchange_id UUID PRIMARY KEY,
    session_id UUID REFERENCES sessions(session_id),
    turn_number INT,
    player_input TEXT,
    entity_responses JSONB,
    chaos_after INT,
    faith_after INT
);

-- Player Progression
CREATE TABLE player_progression (
    progression_id UUID PRIMARY KEY,
    player_id UUID REFERENCES players(player_id),
    metric_name VARCHAR(50),
    metric_value INT,
    recorded_at TIMESTAMP DEFAULT NOW()
);
